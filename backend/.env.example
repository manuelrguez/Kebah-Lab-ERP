# Server
PORT=3001
NODE_ENV=development

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/kebab_lab_erp?sslmode=require

# Auth
JWT_SECRET=cambiar_por_un_secreto_seguro_min_32_chars
JWT_EXPIRES_IN=7d

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-api03-...

# Agora API (reports)
AGORA_API_KEY=
AGORA_BASE_URL=https://api.agora.io

# Delivery platforms
GLOVO_API_KEY=
GLOVO_WEBHOOK_SECRET=
UBEREATS_CLIENT_ID=
UBEREATS_CLIENT_SECRET=
UBEREATS_WEBHOOK_SECRET=
JUSTEAT_API_KEY=
JUSTEAT_WEBHOOK_SECRET=

# File storage
UPLOADS_PATH=./uploads
MAX_FILE_SIZE_MB=10

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173
